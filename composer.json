{
    "name": "abderrahmane/calcite-ui-icons",
    "description": "Calcite UI Icons Blade component for Laravel",
    "keywords": [
        "Calcite",
        "Blade",
        "Icons",
        "Laravel",
        "SVG"
    ],
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Calcite\\Icons\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Calcite\\Icons\\CalciteIconsServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.1",
        "illuminate/support": "^8.0|^9.0|^10.0|^11.0|^12.0|^13.0"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}